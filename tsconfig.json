{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["dom", "esnext"],
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "preserve",
    "jsxImportSource": "@brb-ui/system",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "paths": {
      "@brb-ui/system/jsx-runtime": ["./packages/system/src/jsx-runtime.ts"],
      "@brb-ui/system/jsx-dev-runtime": ["./packages/system/src/jsx-dev-runtime.ts"]
    }
  },
  "include": ["packages", "tools", "vitest.config.ts", "vitest-env.d.ts"],
  "exclude": ["**/node_modules"]
}
