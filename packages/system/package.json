{
  "name": "@brb-ui/system",
  "version": "0.0.9",
  "description": "BRB UI Design System",
  "keywords": [
    "brb",
    "css-in-js",
    "design-system",
    "emotion",
    "style-props",
    "system",
    "ui",
    "ui-component"
  ],
  "homepage": "https://github.com/brb-tech/brb-ui#readme",
  "bugs": {
    "url": "https://github.com/brb-tech/brb-ui/issues"
  },
  "license": "MIT",
  "author": "Hippo <hippowuyufan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brb-tech/brb-ui.git",
    "directory": "packages/system"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf dist && rm -rf build && rm -rf node_modules",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@brb-ui/hooks": "workspace:*",
    "@brb-ui/utils": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "cookie": "^1.1.1",
    "js-cookie": "^3.0.5",
    "lodash.merge": "^4.6.2"
  },
  "devDependencies": {
    "@types/cookie": "^1.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash.merge": "^4.6.9",
    "@types/react": "19.2.14",
    "clean-package": "^2.2.0",
    "react": "19.2.5",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "react": ">=18"
  },
  "clean-package": "./clean-package.config.json",
  "tsup": {
    "format": [
      "cjs",
      "esm"
    ],
    "target": "es2019",
    "clean": true,
    "sourcemap": true
  }
}
