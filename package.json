{
  "name": "brb-ui",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brb-tech/brb-ui.git"
  },
  "author": "Hippo <hippowuyufan@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo run dev --filter=!./examples/*",
    "build": "turbo run build --filter=!./examples/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "dev:storybook": "turbo run dev --filter=@brb-ui/storybook...",
    "build:storybook": "turbo run build --filter=@brb-ui/storybook...",
    "dev:website": "turbo run dev --filter=@brb-ui/website...",
    "build:website": "turbo run build --filter=@brb-ui/website...",
    "dev:examples": "turbo run dev --filter=./examples/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint packages tools docs/storybook vitest.config.ts",
    "format:write": "oxfmt packages tools docs/storybook examples vitest.config.ts vitest-env.d.ts",
    "format:check": "oxfmt --check packages tools docs/storybook examples vitest.config.ts vitest-env.d.ts",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules && rm -rf out",
    "prepare": "husky",
    "version": "changeset version",
    "release": "changeset publish",
    "version:dev": "changeset version --snapshot dev",
    "release:dev": "changeset publish --tag dev"
  },
  "devDependencies": {
    "@brb-ui/testing": "workspace:*",
    "@brb-ui/vite-lib-config": "workspace:*",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.12",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@emotion/babel-plugin": "^11.13.5",
    "@types/node": "^22.13.1",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "oxfmt": "^0.15.0",
    "oxlint": "^0.15.0",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "packageExtensions": {
      "@react-spring/web@*": {
        "peerDependencies": {
          "react": ">=18",
          "react-dom": ">=18"
        }
      },
      "@react-spring/core@*": {
        "peerDependencies": {
          "react": ">=18"
        }
      },
      "@react-spring/shared@*": {
        "peerDependencies": {
          "react": ">=18"
        }
      },
      "@react-spring/animated@*": {
        "peerDependencies": {
          "react": ">=18"
        }
      }
    }
  }
}
