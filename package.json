{
  "name": "brb-ui",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brb-tech/brb-ui.git"
  },
  "author": "Hippo <hippowuyufan@gmail.com>",
  "license": "MIT",
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo run dev --filter=!./examples/*",
    "build": "turbo run build --filter=!./examples/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "dev:storybook": "turbo run dev --filter=@brb-ui/storybook...",
    "build:storybook": "turbo run build --filter=@brb-ui/storybook...",
    "dev:website": "turbo run dev --filter=@brb-ui/website...",
    "build:website": "turbo run build --filter=@brb-ui/website...",
    "dev:examples": "turbo run dev --filter=./examples/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint packages tools docs/storybook vitest.config.mts",
    "format:write": "oxfmt --ignore-path=.oxfmtignore packages tools docs/storybook examples vitest.config.mts vitest-env.d.ts",
    "format:check": "oxfmt --check --ignore-path=.oxfmtignore packages tools docs/storybook examples vitest.config.mts vitest-env.d.ts",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules && rm -rf out",
    "prepare": "husky",
    "version": "changeset version",
    "release": "changeset publish",
    "version:dev": "changeset version --snapshot dev",
    "release:dev": "changeset publish --tag dev"
  },
  "devDependencies": {
    "@brb-ui/testing": "workspace:*",
    "@brb-ui/vite-lib-config": "workspace:*",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@oxfmt/binding-linux-x64-gnu": "0.47.0",
    "@oxlint/binding-linux-x64-gnu": "1.62.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "turbo": "^2.9.7",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "packageExtensions": {
      "@react-spring/web@*": {
        "peerDependencies": {
          "react": ">=18",
          "react-dom": ">=18"
        }
      },
      "@react-spring/core@*": {
        "peerDependencies": {
          "react": ">=18"
        }
      },
      "@react-spring/shared@*": {
        "peerDependencies": {
          "react": ">=18"
        }
      },
      "@react-spring/animated@*": {
        "peerDependencies": {
          "react": ">=18"
        }
      }
    }
  }
}
